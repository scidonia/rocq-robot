{
  "name": "rocq-piler",
  "version": "0.6.0",
  "description": "MCP server for Rocq proof assistant integration via rocq-lsp - your AI companion for theorem proving",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rocq-piler": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "coq",
    "rocq",
    "proof-assistant",
    "lsp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.7"
  }
}
